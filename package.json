{
  "name": "design-token-exporter",
  "version": "0.2.0",
  "description": "Transform your Figma variables and styles into multi-theme and multi-brand design tokens in compliance with the Design Tokens Community Group (DTCG) standards.",
  "main": "code.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "eslint --ext .ts,.tsx --ignore-pattern node_modules .",
    "lint:fix": "eslint --ext .ts,.tsx --ignore-pattern node_modules --fix .",
    "watch": "npm run build -- --watch"
  },
  "author": {
    "name": "Mateus Villain",
    "email": "contato@mateusvillain.com",
    "url": "https://mateusvillain.com"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateusvillain/design-token-exporter.git"
  },
  "bugs": {
    "url": "https://github.com/mateusvillain/design-token-exporter/issues"
  },
  "keywords": [
    "figma",
    "design-tokens",
    "dtcg",
    "variables",
    "tokens",
    "design-system",
    "ui-kit",
    "css",
    "sass",
    "less",
    "stylus",
    "json",
    "export",
    "plugin"
  ],
  "devDependencies": {
    "@figma/eslint-plugin-figma-plugins": "*",
    "@figma/plugin-typings": "*",
    "@typescript-eslint/eslint-plugin": "^6.12.0",
    "@typescript-eslint/parser": "^6.12.0",
    "eslint": "^8.54.0",
    "typescript": "^5.3.2"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:@typescript-eslint/recommended",
      "plugin:@figma/figma-plugins/recommended"
    ],
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "project": "./tsconfig.json"
    },
    "root": true,
    "rules": {
      "@typescript-eslint/no-unused-vars": [
        "error",
        {
          "argsIgnorePattern": "^_",
          "varsIgnorePattern": "^_",
          "caughtErrorsIgnorePattern": "^_"
        }
      ]
    }
  }
}
